# FastAPI Setting
PROJECT_NAME="Climate Digital Twin API"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# PostgreSQL Database
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=climatedb
POSTGRES_PORT=5432
# Construct the SQLAlchemy async URL
# postgresql+asyncpg://user:password@server:port/db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT settings
# To generate a new RS256 private key: `openssl genrsa -out private_key.pem 2048`
# To extract the public key: `openssl rsa -in private_key.pem -outform PEM -pubout -out public_key.pem`
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
ALGORITHM="RS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

# ----------------------------------------------------
# External Services & National Datasets
# ----------------------------------------------------
# India Meteorological Department (IMD) Data API
IMD_API_URL="https://api.imd.gov.in/v1/"
IMD_API_KEY="your_imd_api_key_here"

# ISRO / Bhuvan Spatial Data Portal
ISRO_BHUVAN_URL="https://bhuvan.nrsc.gov.in/api/"
ISRO_API_KEY="your_isro_api_key_here"

# External ML / Digital Twin Inference Endpoints
DIGITAL_TWIN_SIMULATION_URL="http://simulation-engine:8001/api/v1/"
ML_INFERENCE_SERVICE_URL="http://ml-engine:8002/api/v1/"
ML_MODEL_REGISTRY_KEY="your_registry_key_here"

# ----------------------------------------------------
# Data Storage Configuration
# ----------------------------------------------------
# Base directory for all data storage (mounted volume in Docker)
DATA_STORAGE_BASE_PATH="/app/data"

# Sub-directories
DATA_RAW_DIR="raw"
DATA_PROCESSED_DIR="processed"
DATA_MODELS_DIR="models"
DATA_SIMULATIONS_DIR="simulations"
DATA_CACHE_DIR="cache"
DATA_EXPORTS_DIR="exports"

# Storage Backend (local or s3)
STORAGE_BACKEND="local"
# S3_BUCKET_NAME="climate-twin-data"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# S3_ENDPOINT_URL=""
